---
import Section from "../Section.astro";
import { work } from "@cv";
import { Icon } from "astro-icon/components";
---

<Section className={Astro.props.className} title="Experience">
  <ul class="space-y-5">
    {work.map(
      ({ name, startDate, endDate, position, summary, responsibilities, achievements, url, skills, location, location_type }) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Present";

        return (
          <li class="rounded-xl border border-skin-muted/30 bg-skin-fill/40 p-4">
            <div data-expanded="false" class="expand-container space-y-4">
              <header class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h4 class="text-lg font-semibold leading-tight text-skin-base">
                    {position} @ {url ? <a class="text-skin-hue hover:underline" href={url} target="_blank">{name}</a> : name}
                  </h4>
                  {(location || location_type) && (
                    <p class="text-xs text-skin-muted">{location} {location && location_type && "·"} {location_type}</p>
                  )}
                </div>
                <p class="rounded-full bg-skin-hue/10 px-3 py-1 text-xs font-medium text-skin-hue">
                  {startYear} - {endYear}
                </p>
              </header>

              {summary && <p>{summary}</p>}

              {(responsibilities || achievements) && (
                <div class="relative grid gap-3 overflow-hidden pb-1 after:absolute after:bottom-0 after:h-10 after:w-full after:bg-gradient-to-t after:from-skin-fill after:to-transparent after:content-[''] group-data-[expanded=true]:after:hidden max-h-24 group-data-[expanded=true]:max-h-[40rem]">
                  {responsibilities && (
                    <div>
                      <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-skin-base">Responsibilities</p>
                      <ul class="ml-4 list-disc space-y-1">
                        {responsibilities.map((responsibility) => <li class="text-sm text-skin-muted">{responsibility}</li>)}
                      </ul>
                    </div>
                  )}

                  {achievements && (
                    <div>
                      <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-skin-base">Achievements</p>
                      <ul class="ml-4 list-disc space-y-1">
                        {achievements.map((achievement) => <li class="text-sm text-skin-muted">{achievement}</li>)}
                      </ul>
                    </div>
                  )}
                </div>
              )}

              <div class="flex flex-wrap items-center gap-3">
                {(responsibilities || achievements) && (
                  <button class="expand-button inline-flex items-center gap-1 text-xs text-skin-muted underline transition hover:text-skin-base">
                    <span class="expand-text">Show more</span>
                    <Icon name="ri:arrow-down-s-line" class="text-base" />
                  </button>
                )}

                <ul class="flex flex-wrap gap-2" aria-label="Technologies used">
                  {skills &&
                    Object.entries(skills).map(([label, icon]) => (
                      <li class="tag">
                        {icon && <Icon name={icon} width={14} height={14} />} <span>{label}</span>
                      </li>
                    ))}
                </ul>
              </div>
            </div>
          </li>
        );
      },
    )}
  </ul>
</Section>

<script>
  const expandButtons = document.querySelectorAll<HTMLButtonElement>(".expand-button");

  expandButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const container = button.closest<HTMLElement>(".expand-container");
      if (!container) return;
      const expanded = container.dataset.expanded === "true";
      container.dataset.expanded = expanded ? "false" : "true";
      const expandText = button.querySelector<HTMLElement>(".expand-text");
      if (expandText) {
        expandText.textContent = expanded ? "Show more" : "Show less";
      }
    });
  });
</script>
