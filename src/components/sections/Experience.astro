---
import Section from "../Section.astro";
import { work } from "@cv";
import { Icon } from "astro-icon/components";
---

<Section className={Astro.props.className} title="Experience">
  <ul class="space-y-5">
    {work.map(
      (
        { name, startDate, endDate, position, summary, responsibilities, achievements, url, skills, location, location_type },
        index,
      ) => {
        const startYear = startDate;
        const endYear = endDate != null ? endDate : "Present";

        return (
          <li class="rounded-xl border border-skin-muted/30 bg-skin-fill/40 p-4">
            <div class="space-y-4">
              <header class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h4 class="text-lg font-semibold leading-tight text-skin-base">
                    {position} @ {url ? <a class="text-skin-hue hover:underline" href={url} target="_blank">{name}</a> : name}
                  </h4>
                  {(location || location_type) && (
                    <p class="text-xs text-skin-muted">{location} {location && location_type && "·"} {location_type}</p>
                  )}
                </div>
                <p class="rounded-full bg-skin-hue/10 px-3 py-1 text-xs font-medium text-skin-hue">
                  {startYear} - {endYear}
                </p>
              </header>

              {summary &&
                (Array.isArray(summary) ? (
                  <ul class="ml-4 list-disc space-y-1">
                    {summary.map((item) => <li class="text-sm text-skin-muted">{item}</li>)}
                  </ul>
                ) : (
                  <p>{summary}</p>
                ))}

              {responsibilities && (
                <div class="space-y-2">
                  <p class="text-xs font-semibold uppercase tracking-wide text-skin-base">Responsibilities</p>
                  <ul class="ml-4 list-disc space-y-1">
                    {responsibilities.map((responsibility) => <li class="text-sm text-skin-muted">{responsibility}</li>)}
                  </ul>
                </div>
              )}

              {achievements && (
                <div class="space-y-2">
                  <p class="text-xs font-semibold uppercase tracking-wide text-skin-base">Achievements</p>
                  <ul class="ml-4 list-disc space-y-1">
                    {achievements.map((achievement) => <li class="text-sm text-skin-muted">{achievement}</li>)}
                  </ul>
                </div>
              )}

              <div class="flex flex-wrap items-center gap-3">
                <ul class="flex flex-wrap gap-2" aria-label="Technologies used">
                  {skills &&
                    Object.entries(skills).map(([label, icon]) => (
                      <li class="tag">
                        {icon && <Icon name={icon} width={14} height={14} />} <span>{label}</span>
                      </li>
                    ))}
                </ul>
              </div>
            </div>
          </li>
        );
      },
    )}
  </ul>
</Section>
