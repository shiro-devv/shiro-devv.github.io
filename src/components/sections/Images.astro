---
import { Image } from "astro:assets";
import Section from "../Section.astro";

import CV from "@cv";
const images = CV.images!;
---

<Section className={Astro.props.className} title="Gallery">
  {images?.intro && <p class="text-sm text-skin-muted">{images.intro}</p>}
  <div class="grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-4">
    {images.list.map(({ image, alt, desc }) => (
      <div class="group relative overflow-hidden rounded-xl border border-skin-muted/30 bg-skin-button-muted/60">
        <a href={image} data-fancybox="gallery" data-caption={desc} class="block aspect-square">
          <div class="absolute inset-0 animate-pulse bg-skin-muted/20"></div>
          <Image
            src={image}
            alt={alt}
            width={500}
            height={500}
            class="relative h-full w-full object-cover transition duration-300 group-hover:scale-105"
          />
        </a>
      </div>
    ))}
  </div>
</Section>

<script>
  import { Fancybox } from "@fancyapps/ui";
  Fancybox.bind('[data-fancybox="gallery"]', { hideScrollbar: false });
</script>
