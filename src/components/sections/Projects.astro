---
import Section from "../Section.astro";
import { Icon } from "astro-icon/components";
import CV from "@cv";

interface Project {
  name: string;
  description?: string;
  url?: string;
  github?: string;
  isActive?: boolean;
  highlights?: string[];
}

const projects = (CV as { projects?: Project[] }).projects ?? [];
---

<Section className={Astro.props.className} title="Projects">
  {
    projects.length ? (
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {projects.map(({ url, description, highlights = [], name, isActive, github }: Project) => (
          <article class="rounded-xl border border-skin-muted/30 bg-skin-fill/40 p-4 transition hover:-translate-y-0.5 hover:shadow-md">
            <div class="mb-2 flex items-start justify-between gap-2">
              <h4 class="text-base font-semibold text-skin-base">
                {isActive ? (
                  <a class="inline-flex items-center gap-1 hover:text-skin-hue hover:underline" href={url} target="_blank">
                    {name}
                    <Icon name="ri:arrow-right-up-line" />
                  </a>
                ) : (
                  name
                )}
              </h4>
              {github && (
                <a href={github} target="_blank" class="icon-button" title="View repository">
                  <Icon name="mdi:github" width={16} height={16} />
                </a>
              )}
            </div>
            {description && <p>{description}</p>}
            {highlights.length > 0 && (
              <ul class="mt-3 ml-4 list-disc space-y-1">
                {highlights.map((highlight: string) => <li class="text-sm text-skin-muted">{highlight}</li>)}
              </ul>
            )}
          </article>
        ))}
      </div>
    ) : (
      <p class="rounded-xl border border-dashed border-skin-muted/40 p-6 text-sm text-skin-muted">
        Projects will appear here once they are added to <code>cv.json</code>.
      </p>
    )
  }
</Section>
