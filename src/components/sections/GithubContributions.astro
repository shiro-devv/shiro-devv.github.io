---
import Section from "../Section.astro";
import { Icon } from "astro-icon/components";
---

<Section title="GitHub Contributions">
  <div class="flex flex-col gap-4">
    <a
      href="https://github.com/shiro-devv"
      target="_blank"
      id="github-link"
      class="flex items-center gap-3 rounded-xl border border-skin-muted/30 bg-skin-fill/40 p-4 transition hover:-translate-y-0.5 hover:shadow-md"
    >
      <Icon name="mdi:github" class="h-8 w-8 text-skin-hue" />
      <div class="flex flex-col">
        <span class="font-semibold text-skin-base">shiro-devv</span>
        <span id="github-stats" class="text-sm text-skin-muted" aria-live="polite">Loading...</span>
      </div>
      <Icon name="ri:arrow-right-up-line" class="ml-auto h-5 w-5 text-skin-muted" />
    </a>
  </div>
</Section>

<script>
  const GITHUB_STATS_CACHE_KEY = "github-stats-cache";
  const CACHE_DURATION_MS = 10 * 60 * 1000; // 10 mins

  async function fetchGithubData() {
    const statsEl = document.getElementById('github-stats');
    if (!statsEl) return;

    try {
      const cached = localStorage.getItem(GITHUB_STATS_CACHE_KEY);
      if (cached) {
        const parsed = JSON.parse(cached);
        if (Date.now() - parsed.timestamp < CACHE_DURATION_MS) {
          statsEl.textContent = parsed.value;
          return;
        }
      }

      const response = await fetch('https://api.github.com/users/shiro-devv', {
        headers: {
          'Accept': 'application/vnd.github.v3+json'
        }
      });

      if (!response.ok) throw new Error('Failed to fetch');

      const data = await response.json();
      const formatted = `${data.public_repos} repos · ${data.followers} followers`;
      statsEl.textContent = formatted;
      localStorage.setItem(
        GITHUB_STATS_CACHE_KEY,
        JSON.stringify({ value: formatted, timestamp: Date.now() }),
      );
    } catch (error) {
      statsEl.textContent = 'View GitHub Profile';
      console.warn('GitHub stats load failed:', error);
    }
  }

  fetchGithubData();
</script>
