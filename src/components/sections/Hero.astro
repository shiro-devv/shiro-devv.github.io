---
import { basics } from "@cv";
import Section from "@/components/Section.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const { name, label, image, location, profiles, email } = basics;
const { city, region, address } = location;
---

<Section className="gap-6">
  <div class="flex flex-col-reverse gap-6 sm:flex-row sm:items-start sm:justify-between">
    <div class="space-y-3">
      <h1 class="text-3xl font-bold tracking-tight text-skin-base sm:text-4xl">{name}</h1>
      <h2 class="text-base text-skin-muted sm:text-lg">{label}</h2>
      <p class="flex items-center gap-2 text-sm text-skin-muted">
        <Icon name="mdi:map-marker-outline" width={18} height={18} />
        {address}, {city}, {region}
      </p>
      <div class="flex flex-wrap items-center gap-2 print:hidden">
        {email && (
          <a href={`mailto:${email}`} title="Send email" target="_blank" rel="noopener noreferrer" class="icon-button">
            <Icon name="mdi:email-outline" width={18} height={18} />
          </a>
        )}
        {profiles.map(({ network, url, icon }) => (
          <a href={url} title={`Visit ${network}`} target="_blank" rel="noopener noreferrer" class="icon-button">
            <Icon name={icon} width={18} height={18} />
          </a>
        ))}
      </div>
      <footer class="print text-sm">{email}</footer>
    </div>
    <figure class="relative mx-auto w-fit print:hidden sm:mx-0">
      <Image
        class="aspect-square w-28 rounded-2xl border border-skin-muted/30 object-cover shadow-xl shadow-skin-hue/20"
        height={320}
        width={320}
        src={image}
        alt={name}
      />
    </figure>
  </div>
</Section>
